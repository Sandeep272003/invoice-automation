    "pdf-parse": "^1.1.1",
    "dotenv": "^16.4.5",
    "winston": "^3.15.0",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "uuid": "^10.0.0"
