# ═══════════════════════════════════════════════
# Invoice Automation — Environment Variables
# Only 5 required variables. Everything else is derived or has defaults.
# ═══════════════════════════════════════════════

# Groq API Key (required) — get from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# SMTP Email (required) — used for BOTH IMAP receiving AND SMTP sending
# IMAP host is auto-detected (gmail.com → imap.gmail.com, etc.)
SMTP_MAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SMTP From Address (required) — sender email for approval notifications
SMTP_FROM=noreply@yourcompany.com

# Server Port (optional, default: 3000)
PORT=3000